---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import FeatureSection from '../components/FeatureSection.astro';
import CoachMockup from '../components/CoachMockup.astro';
import ChartMockup from '../components/ChartMockup.astro';
import CalendarMockup from '../components/CalendarMockup.astro';
import IntegrationsMockup from '../components/IntegrationsMockup.astro';
import Pricing from '../components/Pricing.astro';
import Testimonials from '../components/Testimonials.astro';
import IntegrationBadges from '../components/IntegrationBadges.astro';
---

<BaseLayout title="Runlab — AI Running Coach">
  <Hero />

  <section id="features">
    <FeatureSection
      label="INTELLIGENT GUIDANCE"
      headline="Grounded in your real metrics."
      body="Most AI coaches give generic advice. Runlab knows your exact physiological state. CTL, ATL, TSB, heart rate zones, and sleep data are injected automatically so your coach knows when to push and when to hold back."
    >
      <CoachMockup />
    </FeatureSection>

    <FeatureSection
      label="DATA VISUALIZATION"
      headline="See your fitness, fatigue, and form at a glance."
      body="The Performance Management Chart (PMC) is the gold standard for pro athletes. We've simplified it for your phone. Know exactly when you're peaking and avoid the dreaded overtraining zone."
      reversed
    >
      <ChartMockup />
    </FeatureSection>

    <FeatureSection
      id="training"
      label="ADAPTIVE PLANS"
      headline="80+ plans from 5K to Marathon."
      body="Whether you're starting your first couch to 5K or chasing a Boston qualifier, our plans schedule dynamically around your race date and adapt to your preferred training days."
    >
      <CalendarMockup />
    </FeatureSection>

    <FeatureSection
      label="INTEGRATIONS"
      headline="Syncs seamlessly. No manual entry."
      body="Import activities instantly from Strava and pull in heart rate, HRV, sleep, and VO2 max from Apple Health to build a complete picture of your physiological readiness."
      reversed
    >
      <IntegrationsMockup />
    </FeatureSection>
  </section>

  <section id="pricing">
    <Pricing />
  </section>

  <!-- <Testimonials /> -->
  <IntegrationBadges />
</BaseLayout>
