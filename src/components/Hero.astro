<style>
  .hero {
    min-height: calc(100vh - 64px);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0 24px;
    background: var(--color-bg);
  }

  .hero-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    display: flex;
    align-items: center;
    gap: 60px;
  }

  .hero-text {
    flex: 0 0 55%;
    max-width: 55%;
  }

  .hero-phone {
    flex: 0 0 45%;
    max-width: 45%;
    display: flex;
    justify-content: center;
  }

  h1 {
    font-family: var(--font-heading);
    font-size: 5.5rem;
    font-weight: 400;
    line-height: 1.1;
    color: var(--color-text);
    margin: 0 0 24px;
  }

  .subtitle {
    font-family: var(--font-body);
    font-size: 1.1rem;
    line-height: 1.7;
    color: var(--color-text-secondary);
    margin: 0 0 32px;
    max-width: 520px;
  }

  .cta-button {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: var(--color-brand-blue);
    color: #FFFFFF;
    font-family: var(--font-body);
    font-size: 1rem;
    font-weight: 600;
    padding: 14px 28px;
    border-radius: var(--radius-pill);
    text-decoration: none;
    transition: opacity 0.2s ease;
  }

  .cta-button:hover {
    opacity: 0.9;
  }

  .cta-button svg {
    flex-shrink: 0;
  }

  .social-proof {
    display: flex;
    align-items: center;
    gap: 14px;
    margin-top: 32px;
    flex-wrap: wrap;
  }

  .avatars {
    display: flex;
    align-items: center;
  }

  .avatar {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-body);
    font-size: 0.8rem;
    font-weight: 700;
    color: #FFFFFF;
    border: 2px solid var(--color-bg);
  }

  .avatar + .avatar {
    margin-left: -10px;
  }

  .avatar-1 {
    background: #6B4CE6;
    z-index: 3;
  }

  .avatar-2 {
    background: #3361C1;
    z-index: 2;
  }

  .avatar-3 {
    background: #8B5CF6;
    z-index: 1;
  }

  .stars {
    display: flex;
    align-items: center;
    gap: 2px;
  }

  .trusted-text {
    font-family: var(--font-body);
    font-size: 0.875rem;
    color: var(--color-text-secondary);
  }

  /* Phone Image */
  .phone-image {
    width: 380px;
    height: auto;
    border-radius: 32px;
    box-shadow: none;
  }

  /* Mobile */
  @media (max-width: 768px) {
    .hero {
      min-height: calc(100vh - 64px);
      padding: 40px 20px;
    }

    .hero-inner {
      flex-direction: column;
      gap: 48px;
      text-align: center;
    }

    .hero-text {
      flex: none;
      max-width: 100%;
    }

    .hero-phone {
      flex: none;
      max-width: 100%;
    }

    h1 {
      font-size: 3.25rem;
    }

    .subtitle {
      max-width: 100%;
      font-size: 1rem;
    }

    .social-proof {
      justify-content: center;
    }
  }
</style>
